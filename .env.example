# Bae Watch environment variables — copy to .env.local and fill in.
# .env.local is gitignored (see *.local). NEVER commit real keys.

# --- Firebase ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- AI (emotional-intelligence features) ---
# Option A (dev/testing only): put your OpenAI key here. NOTE: Vite bundles this
# into the client, so the key is publicly visible. Use only for local testing.
VITE_OPENAI_API_KEY=

# Optional: override the model (default: gpt-4o-mini)
VITE_OPENAI_MODEL=gpt-4o-mini

# Option B (production): point at a serverless proxy that holds the key
# server-side. When set, VITE_OPENAI_API_KEY is ignored on the client.
VITE_AI_PROXY_URL=
